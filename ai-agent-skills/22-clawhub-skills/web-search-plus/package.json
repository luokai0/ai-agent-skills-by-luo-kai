{
  "name": "@openclaw/web-search-plus",
  "version": "3.0.1",
  "description": "Unified multi-provider web search and URL extraction skill with intelligent auto-routing across Serper, Brave, Tavily, Querit, Linkup, Exa, Firecrawl, Perplexity, You.com, and SearXNG.",
  "keywords": [
    "openclaw",
    "skill",
    "search",
    "web-search",
    "serper",
    "brave",
    "tavily",
    "linkup",
    "exa",
    "firecrawl",
    "you",
    "you.com",
    "google-search",
    "research",
    "semantic-search",
    "ai-agent",
    "auto-routing",
    "smart-routing",
    "multi-provider",
    "shopping",
    "product-search",
    "similar-sites",
    "company-discovery",
    "rag",
    "real-time",
    "free-tier",
    "api-aggregator",
    "querit",
    "multilingual-search",
    "web-extract",
    "content-extraction",
    "firecrawl",
    "brave-search",
    "linkup"
  ],
  "author": "robbyczgw-cla",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/robbyczgw-cla/web-search-plus.git"
  },
  "homepage": "https://clawhub.ai/robbyczgw-cla/web-search-plus",
  "bugs": {
    "url": "https://github.com/robbyczgw-cla/web-search-plus/issues"
  },
  "openclaw": {
    "skill": true,
    "triggers": [
      "search",
      "find",
      "look up",
      "research"
    ],
    "capabilities": [
      "web-search",
      "image-search",
      "semantic-search",
      "multi-provider",
      "web-extract"
    ],
    "providers": [
      "serper",
      "brave",
      "tavily",
      "querit",
      "linkup",
      "exa",
      "firecrawl",
      "perplexity",
      "you",
      "searxng"
    ],
    "requirements": {
      "bins": [
        "python3",
        "bash"
      ],
      "env": {
        "SERPER_API_KEY": "optional",
        "BRAVE_API_KEY": "optional",
        "TAVILY_API_KEY": "optional",
        "QUERIT_API_KEY": "optional",
        "LINKUP_API_KEY": "optional",
        "EXA_API_KEY": "optional",
        "FIRECRAWL_API_KEY": "optional",
        "PERPLEXITY_API_KEY": "optional — direct Perplexity provider credential",
        "KILOCODE_API_KEY": "optional — alternative Perplexity provider via Kilo Gateway",
        "YOU_API_KEY": "optional",
        "SEARXNG_INSTANCE_URL": "optional"
      }
    }
  },
  "files": [
    "SKILL.md",
    "README.md",
    "scripts/",
    ".env.example",
    "config.example.json",
    "CHANGELOG.md"
  ]
}
